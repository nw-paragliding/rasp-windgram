#!/bin/bash
export BASEDIR=[BASEDIR]

if [ ! -e $BASEDIR/rasp.env ]
then
	echo "****Error: $BASEDIR/rasp.env not found"
	exit
fi
source $BASEDIR/rasp.env

# WXTOFLY section
#==========================================
export WXTOFLY_ROOT=$BASEDIR/WXTOFLY

export WXTOFLY_LOG=$WXTOFLY_ROOT/LOG
if [ ! -d $WXTOFLY_LOG ]; then
	mkdir -p $WXTOFLY_LOG
fi

#must be YES/NO
export WXTOFLY_DOWNLOAD_RUN_CONFIG=YES

#must be YES/NO
export WXTOFLY_UPLOAD_ENABLED=YES
export WXTOFLY_UPLOAD_ROOT=$WXTOFLY_ROOT/UPLOAD
if [ ! -d $WXTOFLY_UPLOAD_ROOT ]; then
	mkdir -p $WXTOFLY_UPLOAD_ROOT
fi
export WXTOFLY_UPLOAD_SERVER=wxtofly.net
export WXTOFLY_UPLOAD_USERNAME=olneytj

#must be YES/NO
export WXTOFLY_ARCHIVE_ENABLED=NO
export WXTOFLY_ARCHIVE_ROOT=$WXTOFLY_ROOT/ARCHIVE

export WXTOFLY_TEMP=$WXTOFLY_ROOT/TMP
if [ ! -d $WXTOFLY_TEMP ]; then
	mkdir -p $WXTOFLY_TEMP
fi

export WXTOFLY_UTIL=$WXTOFLY_ROOT/UTIL
export WXTOFLY_BLIPSPOT=$WXTOFLY_ROOT/BLIPSPOT
export WXTOFLY_WINDGRAMS=$WXTOFLY_ROOT/WINDGRAMS
export WXTOFLY_RUN=$WXTOFLY_ROOT/RUN
export WXTOFLY_CROP=$WXTOFLY_ROOT/CROP
export WXTOFLY_CONFIG=$WXTOFLY_ROOT/CONFIG
#==========================================

if [ $(basename $0) == "wxtofly.env" ]; then
	ORIG_DIR=$(pwd)
	cd $BASEDIR/WXTOFLY
	bash $@
	cd "$ORIG_DIR"
fi